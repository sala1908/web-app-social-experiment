<main class="page">
  <header class="topbar">
    <h1><a class="home-link" href="/">Web-E-Vil</a></h1>
    <div class="auth-block">
      <a href="/" class="home-button">Home</a>
      {{#if isAuthenticated}}
        <button type="button" id="friends-btn" class="friends-button">Friends</button>
        <span class="user-email">{{user.email}}</span>
        <form method="POST" action="/auth/logout">
          <button type="submit">Logout</button>
        </form>
      {{else}}
        <a href="/login">Login</a>
        <a href="/register">Register</a>
      {{/if}}
    </div>
  </header>
  <section class="toolbar" id="toolbar" data-authenticated="{{isAuthenticated}}">
    <button type="button" data-mode="paint" class="tool-button active">Paint</button>
    <button type="button" data-mode="erase" class="tool-button">Erase</button>
    <label>
      Brush
      <input id="brush-size" type="range" min="1" max="{{appConfig.maxBrushSize}}" value="1" />
      <span id="brush-size-label">1</span>
    </label>
    <label>
      Active Color
      <input id="active-color" type="color" value="#000000" />
    </label>
    <button type="button" id="add-color">Add Color</button>
    {{#if isAdmin}}
      <div class="admin-controls">
        <button type="button" id="admin-reset-canvas">Reset Canvas</button>
        <button type="button" id="admin-reset-limits">Reset Daily Limit</button>
      </div>
    {{/if}}
    <div id="palette" class="palette"></div>
    <div id="usage" class="usage"></div>
  </section>
  <section class="canvas-shell">
    <canvas id="pixel-canvas"></canvas>
  </section>
  <p id="status" class="status"></p>
</main>

<!-- Friends Modal -->
<div id="friends-modal" class="modal-overlay hidden">
  <div class="modal-box">
    <div class="modal-header">
      <h2>Friends</h2>
      <button type="button" id="friends-close" class="modal-close">&times;</button>
    </div>
    <div class="modal-body">
      <div class="friend-add">
        <input id="friend-email" type="email" placeholder="Friend's email" />
        <button type="button" id="friend-send-request">Send Request</button>
        <span id="friend-msg" class="friend-msg"></span>
      </div>
      <h3>Friend Requests</h3>
      <ul id="friend-requests" class="friend-list"></ul>
      <h3>Friends</h3>
      <ul id="friend-list" class="friend-list"></ul>
    </div>
  </div>
</div>

<script>
  window.APP_CONFIG = {{json appConfig}};
  window.APP_USER = {{json user}};
  window.APP_AUTHENTICATED = {{#if isAuthenticated}}true{{else}}false{{/if}};
  window.APP_IS_ADMIN = {{#if isAdmin}}true{{else}}false{{/if}};

  (function () {
    if (!window.APP_AUTHENTICATED) return;

    const modal = document.getElementById("friends-modal");
    const openBtn = document.getElementById("friends-btn");
    const closeBtn = document.getElementById("friends-close");
    const sendBtn = document.getElementById("friend-send-request");
    const emailInput = document.getElementById("friend-email");
    const msgEl = document.getElementById("friend-msg");
    const requestsList = document.getElementById("friend-requests");
    const friendsList = document.getElementById("friend-list");

    function showMsg(text, ok) {
      msgEl.textContent = text;
      msgEl.style.color = ok ? "green" : "#b42318";
      setTimeout(() => { msgEl.textContent = ""; }, 3000);
    }

    async function loadFriends() {
      requestsList.innerHTML = "<li>Loading…</li>";
      friendsList.innerHTML = "<li>Loading…</li>";
      const res = await fetch("/api/friends");
      const data = await res.json();
      const pending = data.friends.filter(f => f.status === "pending");
      const accepted = data.friends.filter(f => f.status === "accepted");

      requestsList.innerHTML = pending.length ? "" : "<li class='empty'>No pending requests.</li>";
      pending.forEach(f => {
        const li = document.createElement("li");
        li.className = "friend-item";
        if (f.direction === "received") {
          li.innerHTML = `<span>${f.email}</span>
            <button data-id="${f.id}" class="btn-accept">Accept</button>
            <button data-id="${f.id}" class="btn-remove">Decline</button>`;
        } else {
          li.innerHTML = `<span>${f.email}</span> <em class="sent-label">Request sent</em>
            <button data-id="${f.id}" class="btn-remove">Cancel</button>`;
        }
        requestsList.appendChild(li);
      });

      friendsList.innerHTML = accepted.length ? "" : "<li class='empty'>No friends yet.</li>";
      accepted.forEach(f => {
        const li = document.createElement("li");
        li.className = "friend-item";
        li.innerHTML = `<span>${f.email}</span>
          <button data-id="${f.id}" class="btn-remove">Remove</button>`;
        friendsList.appendChild(li);
      });
    }

    async function sendRequest() {
      const email = emailInput.value.trim();
      if (!email) return;
      const res = await fetch("/api/friends/request", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ email })
      });
      const data = await res.json();
      if (res.ok) { showMsg("Request sent!", true); emailInput.value = ""; loadFriends(); }
      else showMsg(data.error || "Error", false);
    }

    document.addEventListener("click", async e => {
      if (e.target.classList.contains("btn-accept")) {
        await fetch(`/api/friends/accept/${e.target.dataset.id}`, { method: "POST" });
        loadFriends();
      }
      if (e.target.classList.contains("btn-remove")) {
        await fetch(`/api/friends/${e.target.dataset.id}`, { method: "DELETE" });
        loadFriends();
      }
    });

    openBtn.addEventListener("click", () => { modal.classList.remove("hidden"); loadFriends(); });
    closeBtn.addEventListener("click", () => modal.classList.add("hidden"));
    modal.addEventListener("click", e => { if (e.target === modal) modal.classList.add("hidden"); });
    sendBtn.addEventListener("click", sendRequest);
    emailInput.addEventListener("keydown", e => { if (e.key === "Enter") sendRequest(); });
  })();
</script>
