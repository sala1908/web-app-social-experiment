<main class="page">
  <header class="topbar">
    <h1><a class="home-link" href="/">Web-E-Vil</a></h1>
    <div class="auth-block">
      <a href="/" class="home-button">Home</a>
      <button type="button" id="open-palette-store" class="home-button">Palette Store</button>
      <button type="button" id="open-palette-tutorial" class="home-help-button" aria-label="Palette help">?</button>
      {{#if isAuthenticated}}
        <a href="/profile" class="user-profile-link">{{#if user.displayName}}{{user.displayName}}{{else}}{{user.email}}{{/if}}</a>
        <form method="POST" action="/auth/logout">
          <button type="submit">Logout</button>
        </form>
      {{else}}
        <a href="/login">Login</a>
        <a href="/register">Register</a>
      {{/if}}
    </div>
  </header>

  <section class="toolbar" id="toolbar" data-authenticated="{{isAuthenticated}}">
    <button type="button" data-mode="paint" class="tool-button active">Paint</button>
    <button type="button" data-mode="erase" class="tool-button">Erase</button>

    <label>
      Brush
      <input id="brush-size" type="range" min="1" max="{{appConfig.maxBrushSize}}" value="1" />
      <span id="brush-size-label">1</span>
    </label>

    <label>
      Palette
      <select id="palette-selector"></select>
    </label>

    {{#if isAdmin}}
      <div class="admin-controls">
        <button type="button" id="admin-reset-canvas">Reset Canvas</button>
        <button type="button" id="admin-reset-limits">Reset Daily Limit</button>
      </div>
    {{/if}}

    <div id="palette" class="palette"></div>

    <div id="pixel-count" class="usage"></div>
    <div id="usage" class="usage"></div>
  </section>

  <section class="canvas-shell">
    <button type="button" id="open-tutorial" class="canvas-help-button" aria-label="Open tutorial">?</button>
    <div id="zoom-indicator" class="zoom-indicator" hidden>
      <div id="zoom-indicator-fill" class="zoom-indicator-fill"></div>
    </div>
    <canvas id="pixel-canvas"></canvas>
  </section>

  <div id="interaction-backdrop" class="interaction-backdrop" hidden></div>
  <section id="interaction-modal" class="interaction-modal" aria-hidden="true" hidden>
    <div class="interaction-card">
      <p class="interaction-kicker">Protected space</p>
      <h2 id="interaction-title">Interact with this label</h2>
      <p id="interaction-summary" class="interaction-summary"></p>
      <div class="interaction-actions">
        <button type="button" data-interaction-type="like">Like</button>
        <button type="button" data-interaction-type="dislike">Dislike</button>
        <button type="button" data-interaction-type="report">Report</button>
        <button type="button" data-interaction-type="love">Love</button>
        <button type="button" data-interaction-type="remove">Remove</button>
        <button type="button" data-interaction-type="ban">Ban</button>
        <button type="button" data-interaction-type="friend">Add Friend</button>
        <button type="button" data-interaction-type="name">Name</button>
        <button type="button" data-interaction-type="set-home">Set Home</button>
        <button type="button" data-interaction-type="ai-guess">AI Guess</button>
        <button type="button" data-interaction-type="visit-profile">Visit Profile</button>
      </div>
      <div id="interaction-auth-links" class="interaction-auth-links" hidden>
        <a href="/login">Login</a>
        <a href="/register">Register</a>
      </div>
      <button type="button" id="interaction-close" class="interaction-close">Close</button>
    </div>
  </section>

  <div id="palette-store-backdrop" class="interaction-backdrop" hidden></div>
  <section id="palette-store-modal" class="interaction-modal" aria-hidden="true" hidden>
    <div class="interaction-card palette-store-card">
      <p class="interaction-kicker">Store</p>
      <h2>Palette Store</h2>
      <p id="palette-store-summary" class="interaction-summary"></p>
      <div id="palette-store-grid" class="palette-store-grid"></div>
      <button type="button" id="palette-store-close" class="interaction-close">Close</button>
    </div>
  </section>

  <div id="tutorial-backdrop" class="interaction-backdrop" hidden></div>
  <section id="tutorial-modal" class="interaction-modal" aria-hidden="true" hidden>
    <div class="interaction-card tutorial-card">
      <p class="interaction-kicker">Quick Start</p>
      <h2>Canvas Guide</h2>
      <div class="tutorial-section">
        <h3>Canvas Controls</h3>
        <ul>
          <li>Left click and drag to paint.</li>
          <li>Use Erase mode to clear pixels.</li>
          <li>Right click and drag to pan around the canvas.</li>
          <li>Use + and - to zoom in and out.</li>
          <li>Use mouse wheel over the canvas to change brush size.</li>
        </ul>
      </div>
      <div class="tutorial-section">
        <h3>Protected Groups</h3>
        <ul>
          <li>Click protected labels to open interaction options.</li>
          <li>Hold Ctrl to reveal your own protected labels and tools.</li>
        </ul>
      </div>
      <button type="button" id="tutorial-close" class="interaction-close">Got It</button>
    </div>
  </section>

  <div id="palette-tutorial-backdrop" class="interaction-backdrop" hidden></div>
  <section id="palette-tutorial-modal" class="interaction-modal" aria-hidden="true" hidden>
    <div class="interaction-card tutorial-card">
      <p class="interaction-kicker">Colors & Palettes</p>
      <h2>Palettes</h2>
      <p id="palette-tutorial-summary" class="interaction-summary"></p>
      <div class="tutorial-section">
        <h3>Palette Tokens</h3>
        <ul>
          <li>You start with 1 palette token.</li>
          <li>Earn 1 token each time you level up.</li>
          <li>Use tokens to unlock new color palettes.</li>
        </ul>
      </div>
      <div class="tutorial-section">
        <h3>Using Palettes</h3>
        <ul>
          <li>Open Palette Store from the top bar to browse palettes.</li>
          <li>Click a palette to select it or unlock it with a token.</li>
          <li>Use the Palette dropdown to switch between your unlocked palettes.</li>
          <li>Use number keys and QWERTY keys to pick colors quickly.</li>
        </ul>
      </div>
      <button type="button" id="palette-tutorial-close" class="interaction-close">Got It</button>
    </div>
  </section>

  <div id="guest-paint-backdrop" class="interaction-backdrop" hidden></div>
  <section id="guest-paint-modal" class="interaction-modal" aria-hidden="true" hidden>
    <div class="interaction-card guest-paint-card">
      <p class="interaction-kicker">Login Required</p>
      <h2>Sign in to paint</h2>
      <p class="interaction-summary">Guest browsing is allowed, but drawing is only available to logged-in users.</p>
      <div class="interaction-auth-links guest-paint-links">
        <a href="/login">Login</a>
        <a href="/register">Register</a>
      </div>
      <button type="button" id="guest-paint-close" class="interaction-close">Close</button>
    </div>
  </section>

  <p id="status" class="status"></p>
</main>

<script>
  window.APP_CONFIG = {{json appConfig}};
  window.APP_USER = {{json user}};
  window.APP_AUTHENTICATED = {{json isAuthenticated}};
  window.APP_IS_ADMIN = {{json isAdmin}};

  // Palette help button
  document.getElementById('open-palette-tutorial').addEventListener('click', () => {
    const modal = document.getElementById('palette-tutorial-modal');
    const backdrop = document.getElementById('palette-tutorial-backdrop');
    modal.removeAttribute('hidden');
    backdrop.removeAttribute('hidden');
    modal.setAttribute('aria-hidden', 'false');
  });

  document.getElementById('palette-tutorial-close').addEventListener('click', () => {
    const modal = document.getElementById('palette-tutorial-modal');
    const backdrop = document.getElementById('palette-tutorial-backdrop');
    modal.setAttribute('hidden', '');
    backdrop.setAttribute('hidden', '');
    modal.setAttribute('aria-hidden', 'true');
  });

  document.getElementById('palette-tutorial-backdrop').addEventListener('click', (e) => {
    if (e.target.id === 'palette-tutorial-backdrop') {
      document.getElementById('palette-tutorial-close').click();
    }
  });
</script>
