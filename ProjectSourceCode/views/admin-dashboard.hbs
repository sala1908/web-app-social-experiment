<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{title}}</title>
  <link rel="stylesheet" href="/css/styles.css">
  <style>
    .admin-dashboard {
      max-width: 1400px;
      margin: 0 auto;
      padding: 20px;
    }

    .admin-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 30px;
      border-bottom: 2px solid #666;
      padding-bottom: 15px;
    }

    .admin-header h1 {
      margin: 0;
      font-size: 2.5em;
      color: #ffd700;
    }

    .admin-nav {
      display: flex;
      gap: 10px;
      margin-bottom: 20px;
    }

    .admin-nav button {
      padding: 10px 20px;
      background: #333;
      border: 1px solid #666;
      color: #fff;
      cursor: pointer;
      border-radius: 4px;
      font-size: 14px;
      transition: all 0.3s;
    }

    .admin-nav button.active {
      background: #ffd700;
      color: #000;
    }

    .admin-nav button:hover {
      background: #555;
    }

    .admin-nav button.active:hover {
      background: #ffed4e;
    }

    .admin-section {
      display: none;
      background: #222;
      padding: 20px;
      border-radius: 8px;
      margin-bottom: 20px;
      border: 1px solid #444;
    }

    .admin-section.active {
      display: block;
    }

    .admin-section h2 {
      margin-top: 0;
      color: #ffd700;
      font-size: 1.8em;
      margin-bottom: 20px;
      border-bottom: 1px solid #444;
      padding-bottom: 10px;
    }

    .users-table {
      width: 100%;
      border-collapse: collapse;
      margin-bottom: 20px;
      background: #1a1a1a;
    }

    .users-table thead {
      background: #333;
      position: sticky;
      top: 0;
    }

    .users-table th,
    .users-table td {
      padding: 12px;
      text-align: left;
      border-bottom: 1px solid #444;
    }

    .users-table th {
      color: #ffd700;
      font-weight: bold;
    }

    .users-table tr:hover {
      background: #2a2a2a;
    }

    .user-actions {
      display: flex;
      gap: 8px;
      flex-wrap: wrap;
    }

    .user-actions button {
      padding: 6px 12px;
      font-size: 12px;
      border: none;
      border-radius: 4px;
      cursor: pointer;
      transition: all 0.2s;
    }

    .btn-ban {
      background: #dc3545;
      color: #fff;
    }

    .btn-ban:hover {
      background: #ff6b6b;
    }

    .btn-unban {
      background: #28a745;
      color: #fff;
    }

    .btn-unban:hover {
      background: #5cdb5c;
    }

    .btn-reset-work {
      background: #ff9800;
      color: #fff;
    }

    .btn-reset-work:hover {
      background: #ffb84d;
    }

    .btn-reset-progress {
      background: #2196f3;
      color: #fff;
    }

    .btn-reset-progress:hover {
      background: #64b5f6;
    }

    .btn-edit {
      background: #9c27b0;
      color: #fff;
    }

    .btn-edit:hover {
      background: #ce93d8;
    }

    .form-group {
      margin-bottom: 15px;
    }

    .form-group label {
      display: block;
      margin-bottom: 5px;
      color: #ffd700;
      font-weight: bold;
    }

    .form-group input,
    .form-group select {
      width: 100%;
      max-width: 300px;
      padding: 8px;
      border: 1px solid #555;
      background: #333;
      color: #fff;
      border-radius: 4px;
      font-size: 14px;
    }

    .form-group input:focus,
    .form-group select:focus {
      outline: none;
      border-color: #ffd700;
      box-shadow: 0 0 5px rgba(255, 215, 0, 0.3);
    }

    .btn-submit {
      padding: 10px 20px;
      background: #ffd700;
      color: #000;
      border: none;
      border-radius: 4px;
      cursor: pointer;
      font-weight: bold;
      transition: all 0.2s;
    }

    .btn-submit:hover {
      background: #ffed4e;
      transform: translateY(-2px);
    }

    .message {
      padding: 12px;
      margin-bottom: 15px;
      border-radius: 4px;
      display: none;
    }

    .message.success {
      background: #4caf50;
      color: #fff;
      display: block;
    }

    .message.error {
      background: #dc3545;
      color: #fff;
      display: block;
    }

    .loading {
      text-align: center;
      color: #ffd700;
      padding: 20px;
    }

    .spinner {
      border: 4px solid #444;
      border-top: 4px solid #ffd700;
      border-radius: 50%;
      width: 40px;
      height: 40px;
      animation: spin 1s linear infinite;
      margin: 0 auto 10px;
    }

    @keyframes spin {
      0% {
        transform: rotate(0deg);
      }
      100% {
        transform: rotate(360deg);
      }
    }

    .level-table {
      width: 100%;
      border-collapse: collapse;
      margin-top: 20px;
      background: #1a1a1a;
    }

    .level-table th,
    .level-table td {
      padding: 12px;
      text-align: right;
      border-bottom: 1px solid #444;
    }

    .level-table th:first-child,
    .level-table td:first-child {
      text-align: left;
    }

    .level-table th {
      background: #333;
      color: #ffd700;
      font-weight: bold;
    }

    .level-table tr:hover {
      background: #2a2a2a;
    }

    .config-section {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
      gap: 20px;
      margin-bottom: 20px;
    }

    .config-card {
      background: #333;
      padding: 15px;
      border-radius: 8px;
      border: 1px solid #555;
    }

    .config-card h3 {
      margin-top: 0;
      color: #ffd700;
    }

    .config-card input {
      width: 100%;
      padding: 8px;
      border: 1px solid #555;
      background: #222;
      color: #fff;
      border-radius: 4px;
    }

    .search-box {
      margin-bottom: 20px;
    }

    .search-box input {
      width: 100%;
      max-width: 300px;
      padding: 10px;
      border: 1px solid #555;
      background: #333;
      color: #fff;
      border-radius: 4px;
      font-size: 14px;
    }

    .search-box input:focus {
      outline: none;
      border-color: #ffd700;
      box-shadow: 0 0 5px rgba(255, 215, 0, 0.3);
    }

    .edit-modal {
      display: none;
      position: fixed;
      z-index: 1000;
      left: 0;
      top: 0;
      width: 100%;
      height: 100%;
      background-color: rgba(0, 0, 0, 0.8);
    }

    .edit-modal.active {
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .edit-modal-content {
      background: #222;
      padding: 30px;
      border-radius: 8px;
      border: 2px solid #ffd700;
      max-width: 500px;
      width: 90%;
    }

    .edit-modal-content h3 {
      color: #ffd700;
      margin-top: 0;
    }

    .modal-buttons {
      display: flex;
      gap: 10px;
      margin-top: 20px;
    }

    .modal-buttons button {
      flex: 1;
      padding: 10px;
      border: none;
      border-radius: 4px;
      cursor: pointer;
      font-weight: bold;
      transition: all 0.2s;
    }

    .modal-buttons .btn-submit {
      background: #ffd700;
      color: #000;
    }

    .modal-buttons .btn-submit:hover {
      background: #ffed4e;
    }

    .modal-buttons .btn-cancel {
      background: #555;
      color: #fff;
    }

    .modal-buttons .btn-cancel:hover {
      background: #777;
    }

    .user-id-badge {
      background: #444;
      padding: 2px 6px;
      border-radius: 3px;
      font-family: monospace;
      font-size: 12px;
      color: #bbb;
    }

    .banned-badge {
      background: #dc3545;
      color: #fff;
      padding: 4px 8px;
      border-radius: 3px;
      font-size: 12px;
      font-weight: bold;
    }

    .no-limit-badge {
      background: #2196f3;
      color: #fff;
      padding: 4px 8px;
      border-radius: 3px;
      font-size: 12px;
    }

    .logout-link {
      color: #ffd700;
      text-decoration: none;
      padding: 10px 15px;
      border: 1px solid #666;
      border-radius: 4px;
      transition: all 0.2s;
    }

    .logout-link:hover {
      background: #ffd700;
      color: #000;
    }
  </style>
</head>
<body style="background: #000; color: #fff;">
  <div class="admin-dashboard">
    <div class="admin-header">
      <h1>⚙️ Admin Dashboard</h1>
      <a href="/auth/logout" class="logout-link">Logout</a>
    </div>

    <div class="admin-nav">
      <button class="nav-btn active" data-section="users">Users Management</button>
      <button class="nav-btn" data-section="level-config">Level Configuration</button>
    </div>

    <!-- Users Management Section -->
    <div id="users" class="admin-section active">
      <h2>Users Management</h2>
      <div id="users-message" class="message"></div>

      <div class="search-box">
        <input type="text" id="user-search" placeholder="Search by email or username...">
      </div>

      <div id="users-container" class="loading">
        <div class="spinner"></div>
        <p>Loading users...</p>
      </div>
    </div>

    <!-- Level Configuration Section -->
    <div id="level-config" class="admin-section">
      <h2>Level Configuration</h2>
      <div id="level-config-message" class="message"></div>

      <div class="config-section">
        <div class="config-card">
          <h3>XP Per Level</h3>
          <label>Base XP required for level 0→1</label>
          <input type="number" id="xp-per-level" min="1" placeholder="100">
        </div>
        <div class="config-card">
          <h3>XP Growth Rate</h3>
          <label>Multiplier for each level (1.15 = 15% increase)</label>
          <input type="number" id="xp-growth-rate" min="1" step="0.05" placeholder="1.15">
        </div>
        <div class="config-card">
          <h3>Daily Max Paints</h3>
          <label>Base daily pixel limit</label>
          <input type="number" id="daily-max-paints" min="1" placeholder="100">
        </div>
        <div class="config-card">
          <h3>Daily Paint Growth Rate</h3>
          <label>Multiplier for each level (1.25 = 25% increase)</label>
          <input type="number" id="daily-paint-growth-rate" min="1" step="0.05" placeholder="1.25">
        </div>
      </div>

      <button class="btn-submit" id="update-config-btn">Update Configuration</button>

      <h3 style="margin-top: 30px; color: #ffd700;">Level Progression Table (preview)</h3>
      <div id="level-config-container" class="loading">
        <div class="spinner"></div>
        <p>Loading level configuration...</p>
      </div>
    </div>
  </div>

  <!-- Edit User Modal -->
  <div id="edit-modal" class="edit-modal">
    <div class="edit-modal-content">
      <h3 id="modal-title">Edit User</h3>
      <div id="modal-form"></div>
      <div class="modal-buttons">
        <button class="btn-submit" id="modal-submit-btn">Save</button>
        <button class="btn-cancel" id="modal-cancel-btn">Cancel</button>
      </div>
    </div>
  </div>

  <script>
    const API_BASE = "/api";
    let allUsers = [];

    // Navigation
    document.querySelectorAll(".nav-btn").forEach(btn => {
      btn.addEventListener("click", () => {
        document.querySelectorAll(".nav-btn").forEach(b => b.classList.remove("active"));
        document.querySelectorAll(".admin-section").forEach(s => s.classList.remove("active"));
        
        btn.classList.add("active");
        const sectionId = btn.getAttribute("data-section");
        document.getElementById(sectionId).classList.add("active");

        if (sectionId === "level-config" && !document.getElementById("level-table")) {
          loadLevelConfig();
        }
      });
    });

    // Load and display users
    async function loadUsers() {
      try {
        const response = await fetch(`${API_BASE}/admin/users`);
        const data = await response.json();
        
        if (!data.ok) {
          showMessage("users-message", `Error: ${data.error}`, "error");
          return;
        }

        allUsers = data.users;
        renderUsers(allUsers);
      } catch (error) {
        showMessage("users-message", `Error loading users: ${error.message}`, "error");
      }
    }

    function renderUsers(users) {
      const container = document.getElementById("users-container");
      
      if (users.length === 0) {
        container.innerHTML = "<p>No users found.</p>";
        return;
      }

      let html = `
        <table class="users-table">
          <thead>
            <tr>
              <th>ID</th>
              <th>Email</th>
              <th>Username</th>
              <th>Level</th>
              <th>XP</th>
              <th>Tokens</th>
              <th>Status</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody>
      `;

      users.forEach(user => {
        const banButton = user.banned 
          ? `<button class="user-actions button btn-unban" onclick="toggleBan(${user.id}, false)">Unban</button>`
          : `<button class="user-actions button btn-ban" onclick="toggleBan(${user.id}, true)">Ban</button>`;

        const statusBadge = user.banned ? '<span class="banned-badge">BANNED</span>' : 'Active';
        const dailyLimitText = user.daily_limit_override !== null ? `<span class="no-limit-badge">${user.daily_limit_override}</span>` : 'Default';

        html += `
          <tr>
            <td><span class="user-id-badge">${user.id}</span></td>
            <td>${user.email}</td>
            <td>${user.username || 'N/A'}</td>
            <td>${user.level}</td>
            <td>${user.xp}</td>
            <td>${user.palette_tokens}</td>
            <td>${statusBadge}</td>
            <td>
              <div class="user-actions">
                ${banButton}
                <button class="btn-reset-work" onclick="resetWork(${user.id}, '${user.email}')">Remove Work</button>
                <button class="btn-reset-progress" onclick="resetProgress(${user.id}, '${user.email}')">Reset Progress</button>
                <button class="btn-edit" onclick="openEditModal(${user.id}, '${user.email}', ${user.palette_tokens}, ${user.daily_limit_override || 'null'})">Edit</button>
              </div>
            </td>
          </tr>
        `;
      });

      html += `
          </tbody>
        </table>
      `;

      container.innerHTML = html;
    }

    // Search users
    document.getElementById("user-search").addEventListener("input", (e) => {
      const query = e.target.value.toLowerCase();
      const filtered = allUsers.filter(u => 
        u.email.toLowerCase().includes(query) || 
        (u.username && u.username.toLowerCase().includes(query))
      );
      renderUsers(filtered);
    });

    async function toggleBan(userId, ban) {
      if (!confirm(`Are you sure you want to ${ban ? 'ban' : 'unban'} this user?`)) return;

      try {
        const response = await fetch(`${API_BASE}/admin/users/${userId}/ban`, {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ ban })
        });
        const data = await response.json();

        if (!data.ok) {
          showMessage("users-message", `Error: ${data.error}`, "error");
          return;
        }

        showMessage("users-message", `User ${ban ? 'banned' : 'unbanned'} successfully`, "success");
        loadUsers();
      } catch (error) {
        showMessage("users-message", `Error: ${error.message}`, "error");
      }
    }

    async function resetWork(userId, email) {
      if (!confirm(`Are you sure you want to remove ALL work by ${email}? This cannot be undone!`)) return;

      try {
        const response = await fetch(`${API_BASE}/admin/users/${userId}/reset-work`, {
          method: "POST"
        });
        const data = await response.json();

        if (!data.ok) {
          showMessage("users-message", `Error: ${data.error}`, "error");
          return;
        }

        showMessage("users-message", `Removed ${data.pixelsRemoved} pixels from ${email}`, "success");
        loadUsers();
      } catch (error) {
        showMessage("users-message", `Error: ${error.message}`, "error");
      }
    }

    async function resetProgress(userId, email) {
      if (!confirm(`Are you sure you want to reset level and XP for ${email}?`)) return;

      try {
        const response = await fetch(`${API_BASE}/admin/users/${userId}/reset-progress`, {
          method: "POST"
        });
        const data = await response.json();

        if (!data.ok) {
          showMessage("users-message", `Error: ${data.error}`, "error");
          return;
        }

        showMessage("users-message", `Reset progress for ${email} to Level 0, 0 XP`, "success");
        loadUsers();
      } catch (error) {
        showMessage("users-message", `Error: ${error.message}`, "error");
      }
    }

    function openEditModal(userId, email, tokens, dailyLimit) {
      const modal = document.getElementById("edit-modal");
      const form = document.getElementById("modal-form");
      
      form.innerHTML = `
        <div class="form-group">
          <label>Email: ${email}</label>
        </div>
        <div class="form-group">
          <label for="modal-tokens">Palette Tokens</label>
          <input type="number" id="modal-tokens" value="${tokens}" min="0">
        </div>
        <div class="form-group">
          <label for="modal-daily-limit">Daily Pixel Limit Override</label>
          <input type="number" id="modal-daily-limit" value="${dailyLimit || ''}" min="0" placeholder="Leave empty for default">
        </div>
      `;

      document.getElementById("modal-submit-btn").onclick = async () => {
        const newTokens = parseInt(document.getElementById("modal-tokens").value);
        const newDailyLimit = document.getElementById("modal-daily-limit").value;
        const tokensToAdd = newTokens - tokens;

        try {
          if (tokensToAdd !== 0) {
            const response = await fetch(`${API_BASE}/admin/users/${userId}/add-tokens`, {
              method: "POST",
              headers: { "Content-Type": "application/json" },
              body: JSON.stringify({ tokens: tokensToAdd })
            });
            const data = await response.json();
            if (!data.ok) throw new Error(data.error);
          }

          if (newDailyLimit !== (dailyLimit || '')) {
            const response = await fetch(`${API_BASE}/admin/users/${userId}/set-daily-limit`, {
              method: "POST",
              headers: { "Content-Type": "application/json" },
              body: JSON.stringify({ override: newDailyLimit === '' ? null : parseInt(newDailyLimit) })
            });
            const data = await response.json();
            if (!data.ok) throw new Error(data.error);
          }

          showMessage("users-message", "User updated successfully", "success");
          modal.classList.remove("active");
          loadUsers();
        } catch (error) {
          showMessage("users-message", `Error: ${error.message}`, "error");
        }
      };

      document.getElementById("modal-cancel-btn").onclick = () => {
        modal.classList.remove("active");
      };

      modal.classList.add("active");
    }

    // Level configuration
    async function loadLevelConfig() {
      try {
        const response = await fetch(`${API_BASE}/admin/level-config`);
        const data = await response.json();

        if (!data.ok) {
          showMessage("level-config-message", `Error: ${data.error}`, "error");
          return;
        }

        const config = data.config;
        document.getElementById("xp-per-level").value = config.XP_PER_LEVEL;
        document.getElementById("xp-growth-rate").value = config.XP_GROWTH_RATE;
        document.getElementById("daily-max-paints").value = config.DAILY_MAX_PAINTS;
        document.getElementById("daily-paint-growth-rate").value = config.DAILY_PAINT_GROWTH_RATE;

        renderLevelTable(data.levels);
      } catch (error) {
        showMessage("level-config-message", `Error loading config: ${error.message}`, "error");
      }
    }

    function renderLevelTable(levels) {
      const container = document.getElementById("level-config-container");
      
      let html = `
        <table class="level-table" id="level-table">
          <thead>
            <tr>
              <th>Level</th>
              <th>XP Required for Level</th>
              <th>Daily Pixel Limit</th>
            </tr>
          </thead>
          <tbody>
      `;

      levels.forEach(level => {
        html += `
          <tr>
            <td>Level ${level.level}</td>
            <td>${level.xpRequired}</td>
            <td>${level.dailyLimit}</td>
          </tr>
        `;
      });

      html += `
          </tbody>
        </table>
      `;

      container.innerHTML = html;
    }

    document.getElementById("update-config-btn").addEventListener("click", async () => {
      const xpPerLevel = parseInt(document.getElementById("xp-per-level").value);
      const xpGrowthRate = parseFloat(document.getElementById("xp-growth-rate").value);
      const dailyMaxPaints = parseInt(document.getElementById("daily-max-paints").value);
      const dailyPaintGrowthRate = parseFloat(document.getElementById("daily-paint-growth-rate").value);

      if (!xpPerLevel || !xpGrowthRate || !dailyMaxPaints || !dailyPaintGrowthRate) {
        showMessage("level-config-message", "All fields are required", "error");
        return;
      }

      if (xpPerLevel < 1 || xpGrowthRate < 1 || dailyMaxPaints < 1 || dailyPaintGrowthRate < 1) {
        showMessage("level-config-message", "All values must be >= 1", "error");
        return;
      }

      try {
        const response = await fetch(`${API_BASE}/admin/level-config`, {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({
            XP_PER_LEVEL: xpPerLevel,
            XP_GROWTH_RATE: xpGrowthRate,
            DAILY_MAX_PAINTS: dailyMaxPaints,
            DAILY_PAINT_GROWTH_RATE: dailyPaintGrowthRate
          })
        });
        const data = await response.json();

        if (!data.ok) {
          showMessage("level-config-message", `Error: ${data.error}`, "error");
          return;
        }

        showMessage("level-config-message", data.message, "success");
        setTimeout(() => {
          alert("Configuration updated! Please restart the server for changes to take effect.");
        }, 500);
      } catch (error) {
        showMessage("level-config-message", `Error: ${error.message}`, "error");
      }
    });

    function showMessage(elementId, message, type) {
      const element = document.getElementById(elementId);
      element.textContent = message;
      element.className = `message ${type}`;
      setTimeout(() => {
        element.className = "message";
      }, 5000);
    }

    // Load users on page load
    loadUsers();
  </script>
</body>
</html>
